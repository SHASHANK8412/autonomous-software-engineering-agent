# =============================================================================
# Autonomous Software Engineering Agent — Environment Variables
# Copy this file to .env and fill in values. Never commit .env to git.
# =============================================================================

# Application
APP_NAME=Autonomous Software Engineering Agent
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Gemini API (Milestone: LLM integration)
# GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL (Milestone: persistence)
# DATABASE_URL=postgresql://agent:agent@localhost:5432/agent_db

# Redis (Milestone: caching / task queue)
# REDIS_URL=redis://localhost:6379/0

# ChromaDB (Milestone: vector store)
CHROMA_PERSIST_DIRECTORY=./data/chroma

# GitHub API (Milestone: repository operations)
# GITHUB_TOKEN=your_github_personal_access_token
